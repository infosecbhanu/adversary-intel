# ─── Scanning Platforms ──────────────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here
FOFA_EMAIL=your_fofa_email_here
FOFA_API_KEY=your_fofa_api_key_here

# ─── Passive DNS / WHOIS ─────────────────────────────────────────────────────
SECURITYTRAILS_API_KEY=your_securitytrails_key_here
VALIDIN_API_KEY=your_validin_key_here
DOMAINTOOLS_USER=your_domaintools_user_here
DOMAINTOOLS_KEY=your_domaintools_api_key_here

# ─── Threat Feeds ─────────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_key_here
OTX_API_KEY=your_otx_key_here           # AlienVault OTX (free)

# Anomali ThreatStream (commercial — free trial available)
ANOMALI_URL=https://api.threatstream.com
ANOMALI_USERNAME=your_anomali_username
ANOMALI_API_KEY=your_anomali_api_key

# MISP (self-hosted or community instance)
MISP_URL=https://your-misp-instance.example.com
MISP_KEY=your_misp_automation_key_here
MISP_VERIFY_SSL=true

# OpenCTI (self-hosted or SaaS)
OPENCTI_URL=https://your-opencti-instance.example.com
OPENCTI_TOKEN=your_opencti_api_token_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Abuse.ch feeds (no key needed — included by default)
# MalwareBazaar (no key needed for basic queries)
# crt.sh (public, no key needed)
# BGP.tools ASN lookups (no key needed)

# ─── Application Settings ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
RATE_LIMIT_DELAY=1.0       # seconds between API calls
MAX_PIVOT_DEPTH=3           # maximum pivot chain depth
GRAPH_OUTPUT_DIR=./output/graphs
RULES_OUTPUT_DIR=./output/rules
